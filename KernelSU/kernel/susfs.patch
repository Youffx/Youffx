index 000000000000..bc1cd2b6d748
--- /dev/null
+++ b/fs/susfs.c
@@ -0,0 +1,1305 @@
+#include <linux/version.h>
+#include <linux/cred.h>
+#include <linux/fs.h>
+#include <linux/slab.h>
+#include <linux/seq_file.h>
+#include <linux/printk.h>
